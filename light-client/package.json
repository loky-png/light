{
  "name": "light-client",
  "version": "1.0.0",
  "description": "Light Messenger",
  "main": "electron-dist/main.js",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "electron:dev": "concurrently \"vite\" \"wait-on http://localhost:5173 && electron .\"",
    "electron:build": "vite build && tsc -p tsconfig.electron.json && electron-builder",
    "installer": "vite build && tsc -p tsconfig.electron.json && electron-builder --win nsis",
    "preview": "vite preview"
  },
  "build": {
    "appId": "com.light.messenger",
    "productName": "Light",
    "asar": true,
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "electron-dist/**/*",
      "package.json"
    ],
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ],
      "sign": null,
      "signingHashAlgorithms": [],
      "publisherName": "Light Messenger"
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": true,
      "allowElevation": true,
      "installerIcon": null,
      "uninstallerIcon": null,
      "installerHeader": null,
      "installerHeaderIcon": null,
      "createDesktopShortcut": "always",
      "createStartMenuShortcut": true,
      "shortcutName": "Light Messenger",
      "deleteAppDataOnUninstall": false,
      "runAfterFinish": true,
      "menuCategory": false,
      "artifactName": "Light-Setup.${ext}",
      "license": null,
      "warningsAsErrors": false
    },
    "publish": {
      "provider": "generic",
      "url": "http://155.212.167.68:80/updates/"
    }
  },
  "dependencies": {
    "axios": "^1.15.0",
    "electron-updater": "^6.8.3",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "socket.io-client": "^4.8.3",
    "tweetnacl": "^1.0.3",
    "tweetnacl-util": "^0.15.1"
  },
  "devDependencies": {
    "@types/node": "^20.19.39",
    "@types/react": "^18.2.0",
    "@types/react-dom": "^18.2.0",
    "@vitejs/plugin-react": "^4.2.0",
    "concurrently": "^8.0.0",
    "electron": "^28.0.0",
    "electron-builder": "^24.0.0",
    "png-to-ico": "^3.0.1",
    "typescript": "^5.3.0",
    "vite": "^5.0.0",
    "wait-on": "^7.0.0"
  }
}
